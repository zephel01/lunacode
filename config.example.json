{
  "llm": {
    "provider": "ollama",
    "temperature": 0.7,
    "maxTokens": 4096,
    "openai": {
      "apiKey": "sk-...",
      "baseUrl": "https://api.openai.com/v1",
      "model": "gpt-4o-mini"
    },
    "ollama": {
      "baseUrl": "http://localhost:11434",
      "model": "llama3.1"
    },
    "lmstudio": {
      "baseUrl": "http://localhost:1234/v1",
      "model": "local-model"
    },
    "litellm": {
      "baseUrl": "http://localhost:4000/v1",
      "apiKey": "",
      "model": "gpt-4o-mini"
    },
    "zai": {
      "apiKey": "",
      "model": "glm-5.1",
      "useCodingEndpoint": true
    }
  },
  "agent": {
    "maxIterations": 50,
    "timeout": 15000
  },
  "memory": {
    "enabled": true,
    "maxTokens": 200
  },
  "daemon": {
    "enabled": false,
    "tickIntervalSeconds": 60
  },
  "mcp": {
    "servers": [
      {
        "name": "mcp-wrapper",
        "transport": "stdio",
        "command": "${MCP_WRAPPER_PYTHON}",
        "args": ["${MCP_WRAPPER_SERVER}"],
        "env": {}
      }
    ]
  },
  "routing": {
    "enabled": false,
    "rules": [
      { "taskType": "code_generation", "provider": "ollama", "model": "qwen2.5:14b" },
      { "taskType": "debugging", "provider": "openai", "model": "gpt-4o-mini" },
      { "taskType": "refactoring", "provider": "openai", "model": "gpt-4o-mini" },
      { "taskType": "code_review", "provider": "openai", "model": "gpt-4o-mini" },
      { "taskType": "summarization", "provider": "ollama", "model": "llama3.1" }
    ],
    "defaultProvider": "ollama",
    "fallbackChain": ["ollama", "openai"]
  },
  "selfEval": {
    "enabled": false,
    "scoreThreshold": 7,
    "maxRounds": 2,
    "minResponseLength": 50,
    "evaluateSubAgents": false
  },
  "autoGit": {
    "enabled": false,
    "mode": "commit-and-test",
    "testCommand": "bun test",
    "createPROnTestFailure": false,
    "draftPR": true,
    "baseBranch": "main",
    "commitPrefix": "",
    "includePatterns": [],
    "excludePatterns": ["*.log", "node_modules/**", ".kairos/**"],
    "hooks": {
      "preCommit": "",
      "postCommit": "",
      "postPR": ""
    }
  }
}
