{
  "name": "lunacode",
  "version": "1.0.0",
  "description": "KAIROS - Claude Code inspired autonomous coding agent with 24/7 autonomous capabilities",
  "type": "module",
  "bin": {
    "lunacode": "./src/cli.ts"
  },
  "scripts": {
    "dev": "bun run src/cli.ts",
    "start": "bun run src/cli.ts",
    "test": "bun test",
    "build": "bun build --target node src/cli.ts --outfile dist/cli.js",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test:watch": "bun test --watch",
    "clean": "rimraf dist",
    "docs:build": "echo 'Documentation files are already in docs/'"
  },
  "keywords": [
    "ai",
    "agent",
    "coding",
    "autonomous",
    "cli",
    "assistant",
    "llm",
    "chatbot",
    "automation",
    "development",
    "productivity",
    "tools",
    "memory",
    "daemon",
    "notifications",
    "multi-agent",
    "security",
    "sandbox",
    "buddy-mode",
    "tui",
    "undercover"
  ],
  "author": "LunaCode Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zephel01/lunacode"
  },
  "bugs": {
    "url": "https://github.com/zephel01/lunacode/issues"
  },
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "bun": "^1.3.12",
    "eslint": "^8.0.0",
    "prettier": "^3.0.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "ink": "^4.0.0",
    "openai": "^4.0.0",
    "react": "^18.0.0"
  },
  "files": [
    "dist/cli.js",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    ".gitignore",
    "package.json"
  ]
}
